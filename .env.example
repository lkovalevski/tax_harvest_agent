# ── Copiá este archivo a .env y completá los valores ──────────────────────────
# cp .env.example .env

# Tu clave de API de Anthropic (para extraer datos de los PDFs con Claude)
# Conseguila en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Tu CUIT sin guiones
AFIP_CUIT=20288217549

# Tu clave fiscal de AFIP/ARCA
AFIP_CLAVE=tu_clave_fiscal_aqui

# Carpeta donde ponés los PDFs (por defecto: ./facturas)
CARPETA_FACTURAS=./facturas

# Puerto de la interfaz web (por defecto: 5000)
PORT=5000
